PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Set DATABASE_URL in Vercel to use hosted PostgreSQL.
# If DATABASE_URL is omitted locally, the app falls back to SQLite.
DATABASE_URL=postgres://username:password@hostname:5432/database_name

# Optional Google Sheets sync
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id
GOOGLE_SHEETS_TAB_NAME=Registrations
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
