{
  "name": "launch-pad-2026",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace launch-pad-2026-server\" \"npm run dev --workspace launch-pad-2026-client\"",
    "dev:server": "npm run dev --workspace launch-pad-2026-server",
    "dev:client": "npm run dev --workspace launch-pad-2026-client",
    "build": "npm run build --workspace launch-pad-2026-client",
    "start": "npm run start --workspace launch-pad-2026-server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
